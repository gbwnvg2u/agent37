flowchart TD
    A(("User message received"))
    B(("About to EnterPlanMode?"))
    C{"Already brainstormed?"}
    D["Invoke brainstorming skill"]
    E{"Might any skill apply?"}
    F["Invoke Skill tool"]
    G["Announce: 'Using [skill] to [purpose]'"]
    H{"Has checklist?"}
    I["Create TodoWrite todo per item"]
